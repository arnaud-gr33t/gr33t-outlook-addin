<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>7b3d7e1a-4f1e-4c2a-9d8f-1e5a2c3b4d5e</Id>
  <Version>1.0.2.0</Version>
  <ProviderName>Gr33t</ProviderName>
  <DefaultLocale>fr-FR</DefaultLocale>
  <DisplayName DefaultValue="Gr33t Recovery Layer" />
  <Description DefaultValue="Affiche vos indicateurs de récupération (score + 4 facteurs) dans un panneau latéral Outlook."/>
  <IconUrl DefaultValue="https://arnaud-gr33t.github.io/gr33t-outlook-addin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://arnaud-gr33t.github.io/gr33t-outlook-addin/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://www.gr33t.fr/"/>

  <AppDomains>
    <AppDomain>https://www.gr33t.fr</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://arnaud-gr33t.github.io/gr33t-outlook-addin/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Read" />
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets DefaultMinVersion="1.5">
          <bt:Set Name="Mailbox" />
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>
            <FunctionFile resid="Commands.Url" />

            <!-- ============================================== -->
            <!-- Extension point 1 : Vue Mail (lecture message) -->
            <!-- SupportsNoItemContext = toujours visible même  -->
            <!-- sans message sélectionné                        -->
            <!-- ============================================== -->
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="gr33tGroup">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="gr33tOpenPaneMsgReadButton">
                    <Label resid="Button.Label" />
                    <Supertip>
                      <Title resid="Button.Label" />
                      <Description resid="Button.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- ============================================== -->
            <!-- Extension point 2 : Fenêtre de réunion          -->
            <!-- (organisateur création/édition)                 -->
            <!-- ============================================== -->
            <ExtensionPoint xsi:type="AppointmentOrganizerCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="gr33tGroupOrganizer">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="gr33tOpenPaneApptOrganizerButton">
                    <Label resid="Button.Label" />
                    <Supertip>
                      <Title resid="Button.Label" />
                      <Description resid="Button.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- ============================================== -->
            <!-- Extension point 3 : Fenêtre de réunion          -->
            <!-- (participant consultation)                      -->
            <!-- ============================================== -->
            <ExtensionPoint xsi:type="AppointmentAttendeeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="gr33tGroupAttendee">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="gr33tOpenPaneApptAttendeeButton">
                    <Label resid="Button.Label" />
                    <Supertip>
                      <Title resid="Button.Label" />
                      <Description resid="Button.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://arnaud-gr33t.github.io/gr33t-outlook-addin/assets/icon-16.png" />
          <bt:Image id="Icon.32x32" DefaultValue="https://arnaud-gr33t.github.io/gr33t-outlook-addin/assets/icon-32.png" />
          <bt:Image id="Icon.80x80" DefaultValue="https://arnaud-gr33t.github.io/gr33t-outlook-addin/assets/icon-80.png" />
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url" DefaultValue="https://arnaud-gr33t.github.io/gr33t-outlook-addin/commands.html" />
          <bt:Url id="Taskpane.Url" DefaultValue="https://arnaud-gr33t.github.io/gr33t-outlook-addin/taskpane.html" />
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="Gr33t" />
          <bt:String id="Button.Label" DefaultValue="Gr33t Layer" />
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="Button.Tooltip" DefaultValue="Ouvrir le panneau Gr33t Recovery Layer — indicateurs de récupération" />
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
